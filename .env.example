PORT=4000
NESTJS_API_URL=http://localhost:4000

# JWT *******
JWT_SECRET=secret
JWT_EXPIRATION_TIME=7d # Eg: "2 days", "10h", "7d".

# DB *******
DB_HOST=localhost
DB_PORT=5432
DB_USER=root
DB_PASSWORD=rootroot
DB_NAME=nestjs_architecture
DB_LOGGING=false
DB_SYNCHRONIZE=false
DB_DROP_SCHEMA=false
DB_MAX_CONNECTIONS=20

AUTH_REDIS_URL=

# AWS *******
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

SQS_URL=
SQS_WAIT_TIME_SECONDS=5 # 5 seconds
SQS_POLLING_WAIT_TIME_MS=20  # 20 milliseconds
SQS_VISIBILITY_TIMEOUT=30  # 30 seconds
SQS_BATCH_POLLING=false
SQS_AUTHENTICATION_ERROR_TIMEOUT=3600000 # 1 day

SNS_ARN=

# Pagination *******
PRODUCTS_PAGE_SIZE=50
PRODUCTS_MAX_PAGE_SIZE=200
